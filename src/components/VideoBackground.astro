---
/**
 * Decorative full-bleed background video using a YouTube embed.
 * - Muted, autoplaying, looping (uses the playlist=<id> hack required for loop=1)
 * - Served via youtube-nocookie.com to limit tracking until interaction
 * - aria-hidden + tabindex=-1 + pointer-events:none — purely atmospheric
 * - Optional poster image renders behind the iframe so the area is never empty
 *   while the embed loads.
 *
 * Place inside a position:relative parent. The iframe sizes via viewport
 * units to always cover the parent in 16:9.
 */

interface Props {
  videoId: string;
  poster?: string;
  posterAlt?: string;
  title?: string;
}

const {
  videoId,
  poster,
  posterAlt = '',
  title = 'Background video',
} = Astro.props;

const params = new URLSearchParams({
  autoplay: '1',
  mute: '1',
  controls: '0',
  loop: '1',
  playlist: videoId,
  modestbranding: '1',
  playsinline: '1',
  rel: '0',
  iv_load_policy: '3',
  disablekb: '1',
});

const src = `https://www.youtube-nocookie.com/embed/${videoId}?${params.toString()}`;
---

<div class="video-bg" aria-hidden="true">
  {poster && (
    <img
      class="video-bg__poster"
      src={poster}
      alt={posterAlt}
      loading="eager"
      decoding="async"
    />
  )}
  <iframe
    class="video-bg__frame"
    src={src}
    title={title}
    allow="autoplay; encrypted-media; picture-in-picture"
    loading="eager"
    tabindex="-1"
  ></iframe>
</div>

<style lang="scss">
  .video-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: #0c0c0c;
    pointer-events: none;
  }

  .video-bg__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .video-bg__frame {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Always cover the viewport in 16:9, regardless of orientation. */
    width: 177.78vh;
    height: 100vh;
    min-width: 100vw;
    min-height: 56.25vw;
    transform: translate(-50%, -50%);
    border: 0;
    z-index: 1;
    pointer-events: none;
  }
</style>
