---
const gridItems = [
  { label: 'Mastery in Action', size: 'large' },
  { label: '700 Acre Oasis', size: 'medium' },
  { label: 'Luxury Suite', size: 'medium' },
  { label: 'Performance', size: 'small' },
  { label: 'Fuel & Spirit', size: 'small' },
  { label: 'Quantum Tools', size: 'small' },
  { label: 'Pristine Views', size: 'small' },
];
---

<section class="sanctuary">
  <p class="sanctuary__label reveal-fade">Experience the Sanctuary</p>

  <div class="sanctuary__grid reveal">
    <!-- Top row: 1 large left + 2 stacked right -->
    <div class="sanctuary__item sanctuary__item--large">
      <div class="sanctuary__placeholder"></div>
      <span class="sanctuary__caption">{gridItems[0].label}</span>
    </div>
    <div class="sanctuary__stack">
      <div class="sanctuary__item sanctuary__item--medium">
        <div class="sanctuary__placeholder"></div>
        <span class="sanctuary__caption">{gridItems[1].label}</span>
      </div>
      <div class="sanctuary__item sanctuary__item--medium">
        <div class="sanctuary__placeholder"></div>
        <span class="sanctuary__caption">{gridItems[2].label}</span>
      </div>
    </div>

    <!-- Bottom row: 4 equal -->
    <div class="sanctuary__bottom">
      {gridItems.slice(3).map((item) => (
        <div class="sanctuary__item sanctuary__item--small reveal-stagger">
          <div class="sanctuary__placeholder"></div>
          <span class="sanctuary__caption">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .sanctuary {
    background-color: $color-bg-light;
    padding: $section-padding;

    &__label {
      @include label-text;
      text-align: center;
      color: $color-text-muted;
      margin-bottom: $space-2xl;
    }

    &__grid {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      grid-template-rows: auto auto;
      gap: $grid-gap-sm;
    }

    &__item {
      position: relative;
      @include image-card;

      &:hover .sanctuary__placeholder {
        transform: scale(1.05);
      }

      &:hover .sanctuary__caption {
        opacity: 1;
      }
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, $color-warm-gray 0%, #5a4e3e 100%);
      transition: transform $transition-slow;
    }

    &__caption {
      position: absolute;
      bottom: $space-md;
      left: $space-xl;
      font-family: $font-heading;
      font-size: $text-base;
      font-style: italic;
      color: $color-white;
      opacity: 0.85;
      text-shadow: $shadow-text;
      transition: opacity $transition-base;
    }

    &__item--large {
      grid-column: 1;
      grid-row: 1;

      .sanctuary__placeholder {
        min-height: 400px;
      }

      .sanctuary__caption {
        font-size: $text-lg;
      }
    }

    &__stack {
      grid-column: 2;
      grid-row: 1;
      display: flex;
      flex-direction: column;
      gap: $grid-gap-sm;
    }

    &__item--medium {
      flex: 1;
      @include image-card;
      position: relative;

      .sanctuary__placeholder {
        min-height: 193px;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #7a6e5e 0%, #4a3e2e 100%);
        transition: transform $transition-slow;
      }

      &:hover .sanctuary__placeholder {
        transform: scale(1.05);
      }

      &:hover .sanctuary__caption {
        opacity: 1;
      }
    }

    &__bottom {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: $grid-gap-sm;
    }

    &__item--small {
      .sanctuary__placeholder {
        min-height: 200px;
        background: linear-gradient(135deg, #6b6050 0%, $color-charcoal 100%);
      }

      .sanctuary__caption {
        font-size: $text-sm;
      }
    }

    @include breakpoint-down($bp-md) {
      padding: $section-padding-mobile;

      &__grid {
        grid-template-columns: 1fr;
      }

      &__item--large .sanctuary__placeholder {
        min-height: 220px;
      }

      &__stack {
        flex-direction: row;
      }

      &__item--medium .sanctuary__placeholder {
        min-height: 140px;
      }

      &__bottom {
        grid-template-columns: 1fr 1fr;
      }

      &__item--small .sanctuary__placeholder {
        min-height: 120px;
      }
    }

    @include breakpoint-down($bp-sm) {
      &__stack {
        flex-direction: column;
      }

      &__item--large .sanctuary__placeholder {
        min-height: 180px;
      }

      &__item--medium .sanctuary__placeholder {
        min-height: 120px;
      }

      &__item--small .sanctuary__placeholder {
        min-height: 100px;
      }
    }
  }
</style>
