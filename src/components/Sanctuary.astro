---
const gridItems = [
  { label: 'Mastery in Action', size: 'large' },
  { label: '700 Acre Oasis', size: 'medium' },
  { label: 'Luxury Suite', size: 'medium' },
  { label: 'Performance', size: 'small' },
  { label: 'Fuel & Spirit', size: 'small' },
  { label: 'Quantum Tools', size: 'small' },
  { label: 'Pristine Views', size: 'small' },
];
---

<section class="sanctuary">
  <p class="sanctuary__label reveal-fade">Experience the Sanctuary</p>

  <div class="sanctuary__grid reveal">
    <!-- Top row: 1 large left + 2 stacked right -->
    <div class="sanctuary__item sanctuary__item--large">
      <div class="sanctuary__placeholder"></div>
      <span class="sanctuary__caption">{gridItems[0].label}</span>
    </div>
    <div class="sanctuary__stack">
      <div class="sanctuary__item sanctuary__item--medium">
        <div class="sanctuary__placeholder"></div>
        <span class="sanctuary__caption">{gridItems[1].label}</span>
      </div>
      <div class="sanctuary__item sanctuary__item--medium">
        <div class="sanctuary__placeholder"></div>
        <span class="sanctuary__caption">{gridItems[2].label}</span>
      </div>
    </div>

    <!-- Bottom row: 4 equal -->
    <div class="sanctuary__bottom">
      {gridItems.slice(3).map((item) => (
        <div class="sanctuary__item sanctuary__item--small reveal-stagger">
          <div class="sanctuary__placeholder"></div>
          <span class="sanctuary__caption">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .sanctuary {
    background-color: $color-bg-cream;
    padding: $section-padding;

    &__label {
      font-family: $font-accent;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      text-align: center;
      color: $color-text-muted;
      margin-bottom: 2.5rem;
    }

    &__grid {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    // Top row
    &__grid > .sanctuary__item--large,
    &__grid > .sanctuary__stack {
      // laid out via the top-row wrapper below
    }

    // Top row: large + stack side by side
    &__grid {
      > :first-child,
      > .sanctuary__stack {
        // handled by grid layout below
      }
    }

    // Re-structure: top section as grid
    &__grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      grid-template-rows: auto auto;
      gap: 0.75rem;
    }

    &__item {
      position: relative;
      border-radius: 1rem;
      overflow: hidden;
      cursor: pointer;

      &:hover .sanctuary__placeholder {
        transform: scale(1.05);
      }

      &:hover .sanctuary__caption {
        opacity: 1;
      }
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #8b7d6b 0%, #5a4e3e 100%);
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }

    &__caption {
      position: absolute;
      bottom: 1rem;
      left: 1.25rem;
      font-family: $font-heading;
      font-size: 1rem;
      font-style: italic;
      color: white;
      opacity: 0.85;
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
      transition: opacity 0.3s ease;
    }

    // Large item spans full left column
    &__item--large {
      grid-column: 1;
      grid-row: 1;

      .sanctuary__placeholder {
        min-height: 400px;
      }

      .sanctuary__caption {
        font-size: 1.15rem;
      }
    }

    // Stack = right column, 2 items vertically
    &__stack {
      grid-column: 2;
      grid-row: 1;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    &__item--medium {
      flex: 1;
      border-radius: 1rem;
      overflow: hidden;
      position: relative;
      cursor: pointer;

      .sanctuary__placeholder {
        min-height: 193px;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #7a6e5e 0%, #4a3e2e 100%);
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      }

      &:hover .sanctuary__placeholder {
        transform: scale(1.05);
      }

      &:hover .sanctuary__caption {
        opacity: 1;
      }
    }

    // Bottom row: 4 equal columns
    &__bottom {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }

    &__item--small {
      .sanctuary__placeholder {
        min-height: 200px;
        background: linear-gradient(135deg, #6b6050 0%, #3a3530 100%);
      }

      .sanctuary__caption {
        font-size: 0.9rem;
      }
    }

    @media (max-width: $bp-md) {
      padding: $section-padding-mobile;

      &__grid {
        grid-template-columns: 1fr;
      }

      &__item--large .sanctuary__placeholder {
        min-height: 260px;
      }

      &__stack {
        flex-direction: row;
      }

      &__item--medium .sanctuary__placeholder {
        min-height: 160px;
      }

      &__bottom {
        grid-template-columns: 1fr 1fr;
      }

      &__item--small .sanctuary__placeholder {
        min-height: 150px;
      }
    }
  }
</style>
