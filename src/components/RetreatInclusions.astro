---
interface Props {
  eyebrow?: string;
  heading?: string;
  includes: string[];
  notIncluded: string[];
}

const {
  eyebrow = 'Practicalities',
  heading = "What's included, and what isn't.",
  includes,
  notIncluded,
} = Astro.props;
---

<section class="inclusions">
  <div class="inclusions__inner">
    <header class="inclusions__header reveal">
      <p class="inclusions__eyebrow">{eyebrow}</p>
      <h2 class="inclusions__heading">{heading}</h2>
    </header>

    <div class="inclusions__columns">
      <div class="inclusions__column reveal-stagger">
        <h3 class="inclusions__column-title">Included</h3>
        <ul>
          {includes.map((item) => (
            <li>
              <span class="inclusions__check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7.5L5.5 11L12 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="inclusions__column reveal-stagger">
        <h3 class="inclusions__column-title inclusions__column-title--muted">Not included</h3>
        <ul>
          {notIncluded.map((item) => (
            <li>
              <span class="inclusions__cross" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .inclusions {
    background-color: $color-bg-light;
    padding: $section-padding;

    &__inner {
      max-width: $max-width;
      margin: 0 auto;
    }

    &__header {
      text-align: center;
      max-width: $max-width-narrow;
      margin: 0 auto $space-3xl;
    }

    &__eyebrow {
      @include label-text;
      color: $color-accent;
      margin-bottom: $space-md;
    }

    &__heading {
      font-family: $font-heading;
      font-size: $text-3xl;
      font-style: italic;
      font-weight: $weight-regular;
      color: $color-text-primary;
      line-height: $leading-snug;
    }

    &__columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $space-3xl;

      @include breakpoint-down($bp-md) {
        grid-template-columns: 1fr;
        gap: $space-2xl;
      }
    }

    &__column {
      ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: $space-md;
      }

      li {
        display: flex;
        gap: $space-md;
        align-items: flex-start;
        font-family: $font-body;
        font-size: $text-md;
        color: $color-text-body;
        line-height: $leading-relaxed;
      }
    }

    &__column-title {
      font-family: $font-heading;
      font-size: $text-xl;
      font-style: italic;
      font-weight: $weight-regular;
      color: $color-text-primary;
      margin-bottom: $space-lg;

      &--muted {
        color: $color-text-muted;
      }
    }

    &__check {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba($color-gold, 0.15);
      color: $color-accent;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0.1rem;
    }

    &__cross {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba($color-charcoal, 0.06);
      color: $color-text-muted;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0.1rem;
    }

    @include breakpoint-down($bp-md) {
      padding: $section-padding-mobile;
    }
  }
</style>
