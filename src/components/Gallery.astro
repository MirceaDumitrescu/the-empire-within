---
const features = [
  'Daily Morning Breath & Somatic Flow Sessions — reset circadian rhythm, regulate nervous system',
  'Deep Dialogue Modules — patterns, identity, power, emotional mastery',
  'Bali\'s Purest Healing Modalities — water temples, Balinese cleansing, volcanic hot springs',
  'Curated Environments — botanically designed for deepening inner work',
  'Studio Sessions for Capturing Your Vision',
];
---

<section class="gallery">
  <div class="gallery__strip reveal-fade">
    <div class="gallery__image"><div class="gallery__placeholder"></div></div>
    <div class="gallery__image"><div class="gallery__placeholder"></div></div>
    <div class="gallery__image gallery__image--wide"><div class="gallery__placeholder"></div></div>
    <div class="gallery__image"><div class="gallery__placeholder"></div></div>
  </div>

  <div class="gallery__features reveal">
    {features.map((feature) => (
      <p class="gallery__feature">{feature}</p>
    ))}
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .gallery {
    background-color: $color-bg-light;
    padding: 0 $space-xl $space-4xl;

    &__strip {
      display: grid;
      grid-template-columns: 1fr 1fr 1.5fr 1fr;
      gap: $grid-gap-sm;
      max-width: $max-width;
      margin: 0 auto $space-3xl;
    }

    &__placeholder {
      width: 100%;
      height: 200px;
      background: linear-gradient(135deg, $color-warm-gray 0%, #6b5d4b 100%);
      border-radius: $radius-md;
    }

    &__features {
      max-width: $max-width-narrow;
      margin: 0 auto;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: $space-xs;
    }

    &__feature {
      font-family: $font-body;
      font-size: $text-base;
      font-weight: $weight-regular;
      color: $color-text-body;
      font-style: italic;
      line-height: $leading-relaxed;
    }

    @include breakpoint-down($bp-md) {
      padding: 0 $space-lg $space-3xl;

      &__strip {
        grid-template-columns: 1fr 1fr;
        gap: $space-xs;
      }

      &__placeholder {
        height: 140px;
      }
    }
  }
</style>
