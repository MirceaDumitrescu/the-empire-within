---
---

<header class="header">
  <nav class="header__nav">
    <a href="/" class="header__logo">
      <span class="header__logo-text">The Empire Within</span>
    </a>

    <button class="header__burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="header__links">
      <li><a href="#about">About</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<script>
  const burger = document.querySelector('.header__burger');
  const links = document.querySelector('.header__links');
  const header = document.querySelector('.header');

  function toggleMenu(open: boolean) {
    burger?.classList.toggle('open', open);
    links?.classList.toggle('open', open);
    burger?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger?.addEventListener('click', () => {
    const isOpen = burger.classList.contains('open');
    toggleMenu(!isOpen);
  });

  // Close menu on link click
  links?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  // Sticky header on scroll
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (scrollY > 100) {
      header?.classList.add('sticky');
    } else {
      header?.classList.remove('sticky');
    }
    lastScroll = scrollY;
  }, { passive: true });
</script>

<style lang="scss">
  @use '../styles/variables' as *;

  .header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: $z-header;
    padding: $space-lg $space-xl;
    transition: background $transition-base, padding $transition-base;

    &.sticky {
      position: fixed;
      background: rgba($color-bg-dark, 0.9);
      backdrop-filter: blur(12px);
      padding: $space-md $space-xl;
    }

    &__nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: $max-width;
      margin: 0 auto;
    }

    &__logo-text {
      @include label-text;
      letter-spacing: 0.3em;
      color: $color-text-on-dark;
    }

    &__burger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: $space-xs;
      z-index: $z-header + 1;

      span {
        display: block;
        width: 24px;
        height: 1.5px;
        background: $color-text-on-dark;
        transition: transform $transition-base, opacity $transition-base;
      }

      &.open span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
      }
      &.open span:nth-child(2) {
        opacity: 0;
      }
      &.open span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
      }
    }

    &__links {
      display: flex;
      gap: $space-2xl;

      a {
        @include label-text;
        font-weight: $weight-regular;
        letter-spacing: $tracking-wider;
        color: $color-text-on-dark;
        opacity: 0.8;
        transition: opacity $transition-base;

        &:hover {
          opacity: 1;
        }
      }
    }

    @include breakpoint-down($bp-lg) {
      padding: $space-md $space-lg;

      &__burger {
        display: flex;
      }

      &__links {
        position: fixed;
        top: 0;
        right: 0;
        width: 100%;
        height: 100vh;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: $space-3xl;
        background: rgba($color-bg-dark, 0.95);
        backdrop-filter: blur(12px);
        opacity: 0;
        visibility: hidden;
        transition: opacity $transition-base, visibility $transition-base;

        &.open {
          opacity: 1;
          visibility: visible;
        }

        a {
          font-size: $text-base;
          letter-spacing: $tracking-widest;
          opacity: 0.9;
        }
      }
    }
  }
</style>
