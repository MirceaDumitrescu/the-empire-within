---
const modules = [
  'Daily Morning Breath & Somatic Flow Sessions to reset circadian rhythm & regulate nervous system.',
  'Deep Dialogue Modules: patterns, identity, power, emotional mastery.',
  'WPA (Water Presence Awareness) meditations.',
  'Tantra-based Consciousness Techniques for dissolving mental noise.',
  'Mystic Silence & Integration Ceremonies.',
];
---

<section class="expect" id="experience">
  <h2 class="expect__heading reveal">
    The Immersion
  </h2>

  <ul class="expect__modules reveal">
    {modules.map((module) => (
      <li class="expect__module reveal-stagger">{module}</li>
    ))}
  </ul>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .expect {
    background-color: $color-bg-light;
    padding: $section-padding;
    text-align: center;

    &__heading {
      font-family: $font-heading;
      font-size: $text-2xl;
      font-weight: $weight-medium;
      color: $color-text-primary;
      margin-bottom: 3.5rem;
      letter-spacing: 0.02em;
    }

    &__modules {
      max-width: $max-width-content;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $space-lg $grid-gap-lg;
      text-align: left;
    }

    &__module {
      position: relative;
      font-family: $font-body;
      font-size: $text-md;
      font-weight: $weight-regular;
      color: $color-text-body;
      line-height: $leading-relaxed;
      padding-left: $space-xl;

      &::before {
        content: '';
        position: absolute;
        top: 0.72em;
        left: 0;
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: $color-accent;
      }
    }

    @include breakpoint-down($bp-md) {
      padding: $section-padding-mobile;

      &__modules {
        grid-template-columns: 1fr;
        gap: $space-lg;
      }
    }
  }
</style>
