---
---

<section class="hero">
  <div class="hero__bg">
    <img src="/header.jpeg" alt="" loading="eager" />
  </div>
  <div class="hero__overlay"></div>
  <p class="hero__welcome reveal-fade">Welcome to</p>

  <div class="hero__grid reveal">
    <div class="hero__grid-item hero__grid-item--tall">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item hero__grid-item--tall">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .hero {
    position: relative;
    background-color: $color-bg-dark;
    padding: $space-5xl $space-xl $space-4xl;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 80vh;
    justify-content: center;
    overflow: hidden;

    &__bg {
      position: absolute;
      inset: 0;
      z-index: 0;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        opacity: 0.8;
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        linear-gradient(to bottom, rgba($color-bg-dark, 0.6) 0%, rgba($color-bg-dark, 0.3) 40%, rgba($color-bg-dark, 0.7) 80%, $color-bg-dark 100%),
        radial-gradient(ellipse at center, transparent 0%, rgba($color-bg-dark, 0.5) 70%);
      pointer-events: none;
    }

    &__welcome {
      position: relative;
      z-index: $z-base;
      @include label-text;
      font-size: $text-xs;
      font-weight: $weight-regular;
      letter-spacing: $label-tracking;
      color: $color-text-on-dark;
      opacity: 0.7;
      margin-bottom: $space-xl;
    }

    &__grid {
      position: relative;
      z-index: $z-base;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: $grid-gap-sm;
      max-width: 800px;
      width: 100%;
    }

    &__grid-item {
      &--tall {
        grid-row: span 2;
      }
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      min-height: 140px;
      background: linear-gradient(135deg, $color-charcoal 0%, #2a2520 100%);
      border-radius: $radius-lg;
      overflow: hidden;
    }

    &__grid-item--tall .hero__placeholder {
      min-height: 296px;
    }

    @include breakpoint-down($bp-md) {
      padding: 5rem $space-lg $space-3xl;
      min-height: 60vh;

      &__grid {
        grid-template-columns: repeat(2, 1fr);
        gap: $space-xs;
        max-width: 100%;
      }

      &__placeholder {
        min-height: 80px;
        border-radius: $radius-md;
      }

      &__grid-item--tall .hero__placeholder {
        min-height: 170px;
      }
    }

    @include breakpoint-down($bp-sm) {
      padding: 4rem $space-md $space-xl;
      min-height: 50vh;

      &__placeholder {
        min-height: 60px;
      }

      &__grid-item--tall .hero__placeholder {
        min-height: 130px;
      }
    }
  }
</style>
