---
---

<section class="hero">
  <div class="hero__bg">
    <img src="/header.jpeg" alt="" loading="eager" />
  </div>
  <div class="hero__overlay"></div>
  <p class="hero__welcome reveal-fade">Welcome to</p>

  <div class="hero__logo-frame reveal">
    <img
      class="hero__logo"
      src="/empire-within-logo.png"
      alt="The Empire Within"
      width="1563"
      height="1563"
    />
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .hero {
    position: relative;
    background-color: $color-bg-dark;
    padding: $space-5xl $space-xl $space-4xl;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 80vh;
    justify-content: center;
    overflow: hidden;

    &__bg {
      position: absolute;
      inset: 0;
      z-index: 0;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        opacity: 0.8;
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        linear-gradient(to bottom, rgba($color-bg-dark, 0.6) 0%, rgba($color-bg-dark, 0.3) 40%, rgba($color-bg-dark, 0.7) 80%, $color-bg-dark 100%),
        radial-gradient(ellipse at center, transparent 0%, rgba($color-bg-dark, 0.5) 70%);
      pointer-events: none;
    }

    &__welcome {
      position: relative;
      z-index: $z-base;
      @include label-text;
      font-size: $text-xs;
      font-weight: $weight-regular;
      letter-spacing: $label-tracking;
      color: $color-text-on-dark;
      opacity: 0.7;
      margin-bottom: $space-xl;
    }

    &__logo-frame {
      position: relative;
      z-index: $z-base;
      width: min(30vw, 340px);
      max-width: 100%;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    &__logo {
      width: 100%;
      height: auto;
      filter: drop-shadow(0 18px 35px rgba($color-black, 0.45));
    }

    @include breakpoint-down($bp-md) {
      padding: 5rem $space-lg $space-3xl;
      min-height: 60vh;

      &__logo-frame {
        width: min(58vw, 300px);
      }
    }

    @include breakpoint-down($bp-sm) {
      padding: 4rem $space-md $space-xl;
      min-height: 50vh;

      &__logo-frame {
        width: min(68vw, 240px);
      }
    }
  }
</style>
