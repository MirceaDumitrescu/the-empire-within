---

<section class="hero">
  <div class="hero__overlay"></div>
  <p class="hero__welcome">Welcome to</p>

  <div class="hero__grid">
    <div class="hero__grid-item hero__grid-item--tall">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item hero__grid-item--tall">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
    <div class="hero__grid-item">
      <div class="hero__placeholder"></div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .hero {
    position: relative;
    background-color: $color-bg-dark;
    padding: 6rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 80vh;
    justify-content: center;

    &__overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(60, 50, 40, 0.3) 0%, $color-bg-dark 70%);
      pointer-events: none;
    }

    &__welcome {
      position: relative;
      z-index: 1;
      font-family: $font-accent;
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: $color-text-light;
      opacity: 0.7;
      margin-bottom: 2rem;
    }

    &__grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: 0.75rem;
      max-width: 800px;
      width: 100%;
    }

    &__grid-item {
      &--tall {
        grid-row: span 2;
      }
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      min-height: 140px;
      background: linear-gradient(135deg, #3a3530 0%, #2a2520 100%);
      border-radius: 1rem;
      overflow: hidden;
    }

    &__grid-item--tall .hero__placeholder {
      min-height: 296px;
    }

    @media (max-width: $bp-md) {
      padding: 5rem 1.5rem 3rem;
      min-height: 60vh;

      &__grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
      }

      &__placeholder {
        min-height: 100px;
      }

      &__grid-item--tall .hero__placeholder {
        min-height: 210px;
      }
    }
  }
</style>
