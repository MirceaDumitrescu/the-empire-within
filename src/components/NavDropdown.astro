---
interface NavDropdownGroup {
  title: string;
  items: { label: string; description?: string; href: string }[];
}

interface NavDropdownCta {
  eyebrow?: string;
  title: string;
  description: string;
  href: string;
  cta: string;
}

interface Props {
  id: string;
  groups: NavDropdownGroup[];
  cta?: NavDropdownCta;
}

const { id, groups, cta } = Astro.props;
---

<div
  class="nav-dropdown"
  id={id}
  role="menu"
  data-open="false"
  aria-hidden="true"
>
  <div class="nav-dropdown__panel">
    <div class="nav-dropdown__groups">
      {groups.map((group) => (
        <section class="nav-dropdown__group" aria-label={group.title}>
          <h3 class="nav-dropdown__group-title">{group.title}</h3>
          <ul class="nav-dropdown__list">
            {group.items.map((item) => (
              <li>
                <a href={item.href} class="nav-dropdown__link">
                  <span class="nav-dropdown__link-title">{item.label}</span>
                  {item.description && (
                    <span class="nav-dropdown__link-desc">{item.description}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
    {cta && (
      <aside class="nav-dropdown__cta" aria-label={cta.title}>
        {cta.eyebrow && <p class="nav-dropdown__cta-eyebrow">{cta.eyebrow}</p>}
        <h4 class="nav-dropdown__cta-title">{cta.title}</h4>
        <p class="nav-dropdown__cta-desc">{cta.description}</p>
        <a href={cta.href} class="nav-dropdown__cta-btn">{cta.cta}</a>
      </aside>
    )}
  </div>
</div>

<style lang="scss">
  @use '../styles/variables' as *;

  .nav-dropdown {
    --nav-dropdown-transition: 200ms #{$ease-out};

    &[data-open='false'] {
      pointer-events: none;

      @include breakpoint-up($bp-lg) {
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
      }

      @include breakpoint-down($bp-lg) {
        display: none;
      }
    }

    &[data-open='true'] {
      pointer-events: auto;

      @include breakpoint-up($bp-lg) {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      @include breakpoint-down($bp-lg) {
        display: block;
      }
    }

    @include breakpoint-up($bp-lg) {
      position: absolute;
      top: 100%;
      right: 0;
      left: auto;
      z-index: $z-header + 2;
      padding-top: $space-md;
      transition:
        opacity var(--nav-dropdown-transition),
        visibility var(--nav-dropdown-transition),
        transform var(--nav-dropdown-transition);
    }

    @include breakpoint-down($bp-lg) {
      position: static;
      width: 100%;
      padding-top: $space-md;
    }

    &__panel {
      display: flex;
      gap: $space-2xl;
      align-items: stretch;
      background: rgba($color-charcoal, 0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba($color-accent, 0.2);
      border-top: 2px solid rgba($color-accent, 0.45);
      border-radius: $radius-lg;
      box-shadow: $shadow-lg;
      padding: $space-2xl;
      width: 820px;
      max-width: calc(100vw - #{$space-xl} * 2);

      @include breakpoint-down($bp-lg) {
        flex-direction: column;
        gap: $space-xl;
        width: auto;
        max-width: none;
        box-shadow: none;
        border-radius: $radius-md;
        padding: $space-lg;
      }
    }

    &__groups {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: $space-2xl;
      row-gap: $space-2xl;
      flex: 1 1 auto;
      min-width: 0;

      @include breakpoint-down($bp-lg) {
        grid-template-columns: 1fr;
        row-gap: $space-xl;
      }
    }

    &__group-title {
      @include label-text;
      color: $color-accent;
      margin-bottom: $space-lg;
      font-weight: $weight-semibold;
      white-space: nowrap;
    }

    &__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: $space-lg;
    }

    &__link {
      display: block;
      text-decoration: none;
      color: $color-text-on-dark;
      transition: opacity $transition-base;

      &:hover {
        opacity: 0.95;

        .nav-dropdown__link-title {
          color: $color-accent;
        }
      }
    }

    &__link-title {
      display: block;
      font-family: $font-body;
      font-size: $text-base;
      font-weight: $weight-medium;
      color: $color-text-on-dark;
      margin-bottom: 0.2rem;
      line-height: $leading-snug;
      letter-spacing: 0;
      transition: color $transition-base;
    }

    &__link-desc {
      display: block;
      font-family: $font-body;
      font-size: $text-xs;
      font-weight: $weight-regular;
      color: $color-text-on-dark;
      opacity: 0.55;
      line-height: $leading-normal;
      letter-spacing: 0.01em;
    }

    &__cta {
      flex: 0 0 220px;
      padding-left: $space-2xl;
      border-left: 1px solid $overlay-border-light;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: $space-xs;

      @include breakpoint-down($bp-lg) {
        flex: 0 0 auto;
        width: 100%;
        padding-left: 0;
        padding-top: $space-lg;
        border-left: none;
        border-top: 1px solid $overlay-border-light;
      }
    }

    &__cta-eyebrow {
      @include label-text;
      color: $color-accent;
      opacity: 0.9;
      margin: 0;
    }

    &__cta-title {
      font-family: $font-heading;
      font-size: $text-xl;
      font-weight: $weight-medium;
      color: $color-text-on-dark;
      margin: 0;
      line-height: $leading-snug;
    }

    &__cta-desc {
      font-family: $font-body;
      font-size: $text-xs;
      color: $color-text-on-dark;
      opacity: 0.6;
      line-height: $leading-relaxed;
      letter-spacing: 0.01em;
      margin: 0 0 $space-sm;
    }

    &__cta-btn {
      display: inline-block;
      font-family: $font-accent;
      font-size: $text-sm;
      font-weight: $weight-medium;
      letter-spacing: $tracking-wide;
      text-transform: uppercase;
      padding: 0.85rem $space-xl;
      border-radius: $radius-full;
      background: $color-accent;
      color: $color-bg-dark;
      text-decoration: none;
      transition:
        background $transition-base,
        transform $transition-fast;
      margin-top: $space-xs;

      &:hover {
        background: $color-gold-light;
        transform: translateY(-2px);
      }
    }
  }
</style>
