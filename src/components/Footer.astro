---
const columns = [
  {
    title: 'The Journey',
    items: [
      'Deep healing in silence.',
      'Somatic restoration through Bali\'s ancient waters.',
      'Emotional mastery that starts in the body.',
      'Volcanic hot springs and water temple purification.',
    ],
  },
  {
    title: 'The Environment',
    items: [
      'Private bamboo compound.',
      'Surrounded by jungle canopy and rice terraces.',
      'Every element curated for deep work.',
      'Zero distractions. Maximum immersion.',
    ],
  },
  {
    title: 'The Experience',
    items: [
      'Daily breathwork and somatic sessions.',
      'Personally guided dialogue modules.',
      'Balinese healing ceremonies.',
      'Studio and creative expression space.',
    ],
  },
];
---

<footer class="footer" id="contact">
  <div class="footer__columns">
    {columns.map((col) => (
      <div class="footer__column">
        <h3 class="footer__column-title">{col.title}</h3>
        <ul class="footer__column-list">
          {col.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="footer__bottom">
    <p>&copy; {new Date().getFullYear()} The Empire Within. All rights reserved.</p>
  </div>
</footer>

<style lang="scss">
  @use '../styles/variables' as *;

  .footer {
    background-color: $color-bg-dark;
    color: $color-text-light;
    padding: $section-padding;

    &__columns {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
      max-width: 1000px;
      margin: 0 auto 4rem;
    }

    &__column-title {
      font-family: $font-heading;
      font-size: 1.3rem;
      font-weight: 500;
      font-style: italic;
      margin-bottom: 1.5rem;
      color: $color-accent-gold;
    }

    &__column-list {
      li {
        font-family: $font-body;
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.8;
        opacity: 0.7;
      }
    }

    &__bottom {
      text-align: center;
      padding-top: 2rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);

      p {
        font-family: $font-accent;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        opacity: 0.5;
      }
    }

    @media (max-width: $bp-md) {
      padding: $section-padding-mobile;

      &__columns {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        text-align: center;
      }
    }
  }
</style>
