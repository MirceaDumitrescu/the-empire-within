---
const linkColumns = [
  {
    title: 'Explore',
    links: [
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about' },
      { label: 'Retreats & Services', href: '/retreats' },
      { label: 'Blog', href: '/blog' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'Contact Us', href: '/contact' },
      { label: '1:1 Appointment', href: '/one-on-one' },
      { label: 'Newsletter', href: '#newsletter' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
    ],
  },
];

const socials = [
  { label: 'Instagram', icon: 'instagram', href: '#' },
  { label: 'Facebook', icon: 'facebook', href: '#' },
  { label: 'YouTube', icon: 'youtube', href: '#' },
  { label: 'LinkedIn', icon: 'linkedin', href: '#' },
];
---

<footer class="footer" id="newsletter">
  <!-- Newsletter bar -->
  <div class="footer__newsletter reveal">
    <div class="footer__newsletter-text">
      <h3>Subscribe to Our Newsletter</h3>
      <p>Stay up to date with the latest retreat offerings and transformative insights.</p>
    </div>
    <form class="footer__newsletter-form" onsubmit="return false;">
      <input
        type="email"
        name="email"
        placeholder="Enter your email address"
        autocomplete="email"
        data-newsletter-input
        required
      />
      <button type="submit">Subscribe</button>
    </form>
  </div>

  <!-- Main footer -->
  <div class="footer__main">
    <div class="footer__brand reveal">
      <span class="footer__logo">The Empire<br />Within</span>
    </div>

    <div class="footer__links">
      {linkColumns.map((col) => (
        <div class="footer__column reveal-stagger">
          <h4 class="footer__column-title">{col.title}</h4>
          <ul class="footer__column-list">
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <p>Copyright &copy; {new Date().getFullYear()} The Empire Within. All rights reserved. <span class="footer__bottom-sep">&middot;</span> <a href="/terms">Terms</a> <span class="footer__bottom-sep">&middot;</span> <a href="/privacy">Privacy</a></p>
    <div class="footer__socials">
      {socials.map((s) => (
        <a href={s.href} aria-label={s.label} class="footer__social-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>}
            {s.icon === 'facebook' && <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>}
            {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
            {s.icon === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
          </svg>
        </a>
      ))}
    </div>
  </div>
</footer>

<style lang="scss" is:global>
  @use '../styles/variables' as *;

  .footer {
    background-color: $color-bg-dark;
    color: $color-text-on-dark;
  }

  .footer__newsletter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: $grid-gap-lg;
    padding: $space-3xl $space-4xl;
    border-bottom: 1px solid $overlay-border-light;
    max-width: $max-width;
    margin: 0 auto;

    h3 {
      font-family: $font-heading;
      font-size: $text-xl;
      font-weight: $weight-medium;
      margin-bottom: 0.4rem;
      color: $color-text-on-dark;
    }

    p {
      font-family: $font-body;
      font-size: $text-base;
      opacity: 0.6;
    }
  }

  .footer__newsletter-form {
    display: flex;
    gap: 0;
    flex-shrink: 0;
    min-width: 0;

    input {
      font-family: $font-body;
      font-size: $text-base;
      padding: 0.85rem $space-lg;
      border: 1px solid $overlay-border-medium;
      border-right: none;
      border-radius: $radius-full 0 0 $radius-full;
      background: transparent;
      color: $color-text-on-dark;
      width: min(280px, 100%);
      outline: none;
      transition: border-color $transition-base;

      &::placeholder {
        color: rgba(255, 255, 255, 0.35);
      }

      &:focus {
        border-color: $color-accent;
      }
    }

    button {
      font-family: $font-accent;
      font-size: $text-sm;
      font-weight: $weight-medium;
      letter-spacing: $tracking-wide;
      padding: 0.85rem $space-xl;
      border: none;
      border-radius: 0 $radius-full $radius-full 0;
      background: $color-accent;
      color: $color-bg-dark;
      cursor: pointer;
      transition: background $transition-base, transform $transition-fast;
      white-space: nowrap;

      &:hover {
        background: $color-gold-light;
        transform: translateX(2px);
      }
    }
  }

  .footer__main {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: $grid-gap-xl;
    padding: $space-4xl;
    max-width: $max-width;
    margin: 0 auto;
    border-bottom: 1px solid $overlay-border-light;
  }

  .footer__brand {
    display: flex;
    align-items: flex-start;
  }

  .footer__logo {
    font-family: $font-heading;
    font-size: $text-4xl;
    font-weight: $weight-semibold;
    line-height: $leading-tight;
    color: $color-text-on-dark;
    letter-spacing: $tracking-tight;
  }

  .footer__links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: $grid-gap-md;
  }

  .footer__column-title {
    @include label-text;
    font-weight: $weight-semibold;
    letter-spacing: $tracking-wider;
    color: $color-accent;
    margin-bottom: $space-xl;
  }

  .footer__column-list {
    li {
      margin-bottom: 0.6rem;
    }

    a {
      font-family: $font-body;
      font-size: $text-base;
      font-weight: $weight-regular;
      color: $color-text-on-dark;
      opacity: 0.6;
      transition: opacity $transition-base;

      &:hover {
        opacity: 1;
      }
    }
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: $space-lg $space-4xl;
    max-width: $max-width;
    margin: 0 auto;

    p {
      font-family: $font-accent;
      font-size: $text-xs;
      letter-spacing: $tracking-wide;
      opacity: 0.4;

      a {
        opacity: 0.7;
        transition: opacity $transition-base;

        &:hover {
          opacity: 1;
        }
      }
    }
  }

  .footer__bottom-sep {
    margin: 0 $space-xs;
  }

  .footer__socials {
    display: flex;
    gap: $space-md;
  }

  .footer__social-icon {
    color: $color-text-on-dark;
    opacity: 0.4;
    transition: opacity $transition-base, transform $transition-base;

    &:hover {
      opacity: 1;
      transform: translateY(-2px);
    }
  }

  @media (max-width: $bp-lg) {
    .footer__newsletter {
      flex-direction: column;
      align-items: flex-start;
      padding: $space-3xl $space-xl;
      gap: $space-lg;
    }

    .footer__newsletter-form {
      width: 100%;

      input {
        width: 100%;
      }
    }

    .footer__main {
      grid-template-columns: 1fr;
      gap: $grid-gap-lg;
      padding: $space-3xl $space-xl;
    }

    .footer__brand {
      justify-content: center;
    }

    .footer__logo {
      text-align: center;
    }
  }

  @media (max-width: $bp-md) {
    .footer__links {
      grid-template-columns: 1fr;
      gap: $grid-gap-md;
      text-align: center;
    }

    .footer__bottom {
      flex-direction: column;
      gap: $space-xl;
      padding: $space-lg $space-xl;
      text-align: center;
    }
  }
</style>

<script>
  /**
   * Newsletter link UX:
   * Clicking any a[href="#newsletter"] (e.g. the Connect column link)
   * smooth-scrolls to the footer signup bar and focuses the email input,
   * so the user lands ready to type rather than hunting for the field.
   */
  type LenisLike = {
    scrollTo: (
      target: string | HTMLElement,
      opts?: { offset?: number; duration?: number; onComplete?: () => void },
    ) => void;
  };

  function focusNewsletterInput() {
    const input = document.querySelector<HTMLInputElement>('[data-newsletter-input]');
    if (!input) return;
    // preventScroll because Lenis (or scrollIntoView) has already handled position.
    input.focus({ preventScroll: true });
  }

  function scrollAndFocus(target: HTMLElement) {
    const lenis = (window as unknown as { lenis?: LenisLike }).lenis;

    if (lenis) {
      lenis.scrollTo(target, {
        offset: 0,
        duration: 1.2,
        onComplete: focusNewsletterInput,
      });
      return;
    }

    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    // Fallback: focus once the smooth scroll has had time to settle.
    window.setTimeout(focusNewsletterInput, 800);
  }

  document.querySelectorAll<HTMLAnchorElement>('a[href="#newsletter"]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const target = document.getElementById('newsletter');
      if (!target) return;
      event.preventDefault();
      scrollAndFocus(target);
    });
  });
</script>
