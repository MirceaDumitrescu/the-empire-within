---
interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string;
  bullets?: string[];
  notFor?: string[];
}

const {
  eyebrow = 'Who This Is For',
  heading = 'For those who arrive ready to slow down.',
  description = 'The 1:1 immersion is small, deliberate, and not for everyone. It is built for practitioners who want a private container, who already know that intensity is not the same as depth, and who can give the work a full week of attention.',
  bullets = [
    'Leaders and founders carrying consequential decisions, looking to reset rather than recover.',
    'Creators in seasons of transition who need to find their own rhythm again.',
    'Long-time practitioners ready for a private container instead of another group retreat.',
    'Those who have worked privately before and value discretion, pacing, and tailored attention.',
  ],
  notFor = [
    'Those looking for entertainment, intensity for its own sake, or a quick fix.',
    'Anyone unable to set the work aside for the duration of the week.',
    'Those who would prefer the camaraderie of a group cohort — our retreats are a better fit.',
  ],
} = Astro.props;
---

<section class="private-audience">
  <div class="private-audience__inner">
    <header class="private-audience__header reveal">
      <p class="private-audience__eyebrow">{eyebrow}</p>
      <h2 class="private-audience__heading">{heading}</h2>
      <p class="private-audience__description">{description}</p>
    </header>

    <div class="private-audience__columns">
      <div class="private-audience__column reveal-stagger">
        <h3 class="private-audience__column-title">It is for</h3>
        <ul>
          {bullets.map((item) => (
            <li>
              <span class="private-audience__check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7.5L5.5 11L12 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="private-audience__column reveal-stagger">
        <h3 class="private-audience__column-title private-audience__column-title--muted">It is not for</h3>
        <ul>
          {notFor.map((item) => (
            <li>
              <span class="private-audience__cross" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .private-audience {
    background-color: $color-bg-light;
    padding: $section-padding;

    &__inner {
      max-width: $max-width;
      margin: 0 auto;
    }

    &__header {
      text-align: center;
      max-width: $max-width-narrow;
      margin: 0 auto $space-4xl;
    }

    &__eyebrow {
      @include label-text;
      color: $color-accent;
      margin-bottom: $space-md;
    }

    &__heading {
      font-family: $font-heading;
      font-size: $text-3xl;
      font-style: italic;
      font-weight: $weight-regular;
      color: $color-text-primary;
      line-height: $leading-snug;
      margin-bottom: $space-md;
    }

    &__description {
      font-family: $font-body;
      font-size: $text-md;
      color: $color-text-body;
      line-height: $leading-relaxed;
    }

    &__columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $space-3xl;

      @include breakpoint-down($bp-md) {
        grid-template-columns: 1fr;
        gap: $space-2xl;
      }
    }

    &__column {
      ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: $space-md;
      }

      li {
        display: flex;
        gap: $space-md;
        align-items: flex-start;
        font-family: $font-body;
        font-size: $text-md;
        color: $color-text-body;
        line-height: $leading-relaxed;
      }
    }

    &__column-title {
      font-family: $font-heading;
      font-size: $text-xl;
      font-style: italic;
      font-weight: $weight-regular;
      color: $color-text-primary;
      margin-bottom: $space-lg;

      &--muted {
        color: $color-text-muted;
      }
    }

    &__check {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba($color-gold, 0.15);
      color: $color-accent;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0.1rem;
    }

    &__cross {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba($color-charcoal, 0.06);
      color: $color-text-muted;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0.1rem;
    }

    @include breakpoint-down($bp-md) {
      padding: $section-padding-mobile;
    }
  }
</style>
