---

<section class="quote">
  <div class="quote__overlay"></div>
  <div class="quote__content reveal-fade">
    <h2 class="quote__text">
      When the mind rests, the empire rises.
    </h2>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .quote {
    position: relative;
    background-color: $color-charcoal;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: $section-padding;
    overflow: hidden;

    &__overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(80, 70, 55, 0.4) 0%, $overlay-dark 100%);
      pointer-events: none;
    }

    &__content {
      position: relative;
      z-index: $z-base;
      text-align: center;
      max-width: 800px;
    }

    &__text {
      font-family: $font-heading;
      font-size: $text-4xl;
      font-weight: $weight-regular;
      font-style: italic;
      color: $color-text-on-dark;
      line-height: 1.3;
      letter-spacing: 0.02em;
    }

    @include breakpoint-down($bp-md) {
      min-height: 40vh;
      padding: $section-padding-mobile;
    }
  }
</style>
