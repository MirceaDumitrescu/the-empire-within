---

<section class="quote">
  <div class="quote__overlay"></div>
  <div class="quote__content reveal-fade">
    <h2 class="quote__text">
      Power is peace, when peace becomes deliberate.
    </h2>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .quote {
    position: relative;
    background-color: #3a3530;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: $section-padding;
    overflow: hidden;

    &__overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(80, 70, 55, 0.4) 0%, rgba(30, 25, 20, 0.9) 100%);
      pointer-events: none;
    }

    &__content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 800px;
    }

    &__text {
      font-family: $font-heading;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 400;
      font-style: italic;
      color: $color-text-light;
      line-height: 1.3;
      letter-spacing: 0.02em;
    }

    @media (max-width: $bp-md) {
      min-height: 40vh;
      padding: $section-padding-mobile;
    }
  }
</style>
