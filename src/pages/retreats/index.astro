---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { retreats } from '../../data/retreats';

const retreat = retreats[0];
---

<Layout
  title="Retreat — The Empire Within"
  description={retreat.shortDescription}
>
  <Header />
  <main>
    <PageHero
      eyebrow="Retreat"
      title={retreat.title}
      tagline={retreat.subtitle}
      size="md"
    />

    <section class="retreat-listing">
      <div class="retreat-listing__inner">
        <header class="retreat-listing__group-header reveal">
          <p class="retreat-listing__group-label">Invitation-only</p>
          <h2 class="retreat-listing__group-heading">The silent restoration for the human behind the power.</h2>
          <p class="retreat-listing__group-desc">
            A Seven-day, high-end Immersive Sanctuary for Emotional and Somatic Mastery in the most secluded sanctuary in Bali.
          </p>
        </header>

        <div class="retreat-listing__grid">
          <a class="retreat-card reveal-stagger" href={`/retreats/${retreat.slug}`}>
            <div class="retreat-card__media">
              <ImagePlaceholder
                src={retreat.images?.[0]?.src}
                alt={retreat.images?.[0]?.alt ?? retreat.title}
                label={retreat.images?.[0]?.label ?? retreat.title}
                aspectRatio="4 / 3"
                rounded={false}
              />
            </div>
            <div class="retreat-card__body">
              <p class="retreat-card__category">{retreat.category}</p>
              <h3 class="retreat-card__title">{retreat.title}</h3>
              <p class="retreat-card__desc">{retreat.shortDescription}</p>
              <dl class="retreat-card__meta">
                <div>
                  <dt>Duration</dt>
                  <dd>{retreat.duration}</dd>
                </div>
                <div>
                  <dt>Location</dt>
                  <dd>{retreat.location}</dd>
                </div>
              </dl>
              <span class="retreat-card__more">
                View retreat
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                  <path d="M1 5H12.5M12.5 5L8.5 1M12.5 5L8.5 9" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style lang="scss" is:global>
  @use '../../styles/variables' as *;

  .retreat-listing {
    background-color: $color-bg-light;
    padding: $section-padding;

    &__inner {
      max-width: $max-width;
      margin: 0 auto;
    }

    &__group-header {
      max-width: $max-width-narrow;
      margin: 0 auto $space-3xl;
      text-align: center;

      &--spaced {
        margin-top: $space-5xl;
      }
    }

    &__group-label {
      @include label-text;
      color: $color-accent;
      margin-bottom: $space-md;
    }

    &__group-heading {
      font-family: $font-heading;
      font-size: $text-3xl;
      font-style: italic;
      font-weight: $weight-regular;
      color: $color-text-primary;
      line-height: $leading-snug;
      margin-bottom: $space-md;
    }

    &__group-desc {
      font-family: $font-body;
      font-size: $text-md;
      color: $color-text-body;
      line-height: $leading-relaxed;
    }

    &__grid {
      display: grid;
      grid-template-columns: minmax(0, 640px);
      justify-content: center;
      gap: $space-2xl $space-xl;

      @include breakpoint-down($bp-md) {
        grid-template-columns: 1fr;
      }
    }

    @include breakpoint-down($bp-md) {
      padding: $section-padding-mobile;
    }
  }

  .retreat-card {
    display: flex;
    flex-direction: column;
    background: $color-white;
    border: 1px solid rgba($color-charcoal, 0.08);
    border-radius: $radius-md;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform $transition-base,
      border-color $transition-base,
      box-shadow $transition-base;

    &:hover {
      transform: translateY(-3px);
      border-color: rgba($color-accent, 0.4);
      box-shadow: $shadow-md;

      .retreat-card__title {
        color: $color-accent;
      }

      .retreat-card__more svg {
        transform: translateX(3px);
      }
    }

    &__media {
      width: 100%;
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: $space-sm;
      padding: $space-xl;
      flex: 1;
    }

    &__category {
      @include label-text;
      color: $color-accent;
      margin: 0;
    }

    &__title {
      font-family: $font-heading;
      font-size: $text-xl;
      font-weight: $weight-medium;
      color: $color-text-primary;
      line-height: $leading-snug;
      margin: 0;
      transition: color $transition-base;
    }

    &__desc {
      font-family: $font-body;
      font-size: $text-sm;
      color: $color-text-body;
      line-height: $leading-relaxed;
      margin: 0 0 $space-sm;
    }

    &__meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $space-md;
      margin: 0 0 $space-md;
      padding: $space-md 0;
      border-top: 1px solid rgba($color-charcoal, 0.08);
      border-bottom: 1px solid rgba($color-charcoal, 0.08);

      div {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      dt {
        @include label-text;
        font-size: 0.65rem;
        color: $color-text-muted;
      }

      dd {
        font-family: $font-body;
        font-size: $text-sm;
        color: $color-text-body;
        margin: 0;
      }
    }

    &__more {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: $font-accent;
      font-size: $text-xs;
      font-weight: $weight-medium;
      letter-spacing: $tracking-wide;
      text-transform: uppercase;
      color: $color-text-primary;
      margin-top: auto;

      svg {
        transition: transform $transition-base;
      }
    }
  }
</style>
