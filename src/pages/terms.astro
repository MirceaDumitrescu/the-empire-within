<Layout
  title="Terms & Conditions — The Empire Within"
  description="The terms and conditions governing the use of theempirewithin.com and our retreat services."
>
  <Header />
  <main>
    <LegalDocument
      eyebrow="Legal"
      title="Terms & Conditions"
      lastUpdated="May 10, 2026"
      intro={[
        'These Terms describe the rules for using our Website and the conditions that apply to applications, bookings, and participation in our Retreats and 1:1 Immersions.',
        'They are written to be as plain as possible, but they are still a legal document. Please read them carefully and ask if anything is unclear.',
      ]}
      sections={sections}
      contactEmail="hello@theempirewithin.com"
    />
  </main>
  <Footer />
</Layout>
