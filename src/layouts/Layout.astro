---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Empire Within — Bali Retreat',
  description = 'The Empire Within is a seven-day, high-end immersive sanctuary for emotional and somatic mastery in Bali.',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
  @use '../styles/variables' as *;

  /* Lenis smooth scroll */
  html.lenis, html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  /* Scroll reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity $transition-reveal,
                transform $transition-reveal;

    &.visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal-fade {
    opacity: 0;
    transition: opacity 1.2s $ease-out;

    &.visible {
      opacity: 1;
    }
  }

  .reveal-stagger {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s $ease-out,
                transform 0.7s $ease-out;

    &.visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Parallax elements */
  .parallax-slow {
    will-change: transform;
  }
</style>

<script>
  import Lenis from 'lenis';

  // Buttery smooth scroll
  const lenis = new Lenis({
    duration: 1.4,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smoothWheel: true,
  });

  // Expose so other scripts (e.g. Footer newsletter link) can drive smooth scroll.
  (window as unknown as { lenis?: Lenis }).lenis = lenis;

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  /**
   * Global anchor-link smooth scrolling.
   * Intercepts clicks on same-page <a href="#id"> links and routes them
   * through Lenis so the smooth-scroll library actually moves the page
   * (a default click would jump instantly past Lenis). Honours each
   * target's CSS scroll-margin-top, so sections that compensate for the
   * sticky header (e.g. legal TOC, retreat sections) land in the right place.
   */
  const HEADER_OFFSET_PX = 96;

  document.addEventListener('click', (event) => {
    // A more specific handler (e.g. footer newsletter focus) may have already handled this.
    if (event.defaultPrevented) return;

    const target = event.target as Element | null;
    if (!target) return;

    const link = target.closest('a[href^="#"]') as HTMLAnchorElement | null;
    if (!link) return;

    const href = link.getAttribute('href');
    if (!href || href === '#') return;

    // Same-document only (e.g. don't hijack `/blog#x` from a different page;
    // those will navigate normally and the browser will land near the anchor).
    if (link.pathname && link.pathname !== window.location.pathname) return;

    const id = href.slice(1);
    const dest = document.getElementById(id);
    if (!dest) return;

    event.preventDefault();

    // Prefer the element's scroll-margin-top if defined, else use a header-safe offset.
    const cs = window.getComputedStyle(dest);
    const scrollMarginTop = parseFloat(cs.scrollMarginTop || '0');
    const offset = -(scrollMarginTop || HEADER_OFFSET_PX);

    lenis.scrollTo(dest, { offset, duration: 1.1 });

    // Update URL hash without causing a jump.
    if (history.replaceState) {
      history.replaceState(null, '', href);
    }
  });

  // Scroll reveal with IntersectionObserver
  const revealElements = document.querySelectorAll('.reveal, .reveal-fade, .reveal-stagger');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Stagger children if parent has stagger items
          const staggerItems = entry.target.querySelectorAll('.reveal-stagger');
          if (staggerItems.length > 0) {
            staggerItems.forEach((item, i) => {
              setTimeout(() => item.classList.add('visible'), i * 120);
            });
          }
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
  );

  revealElements.forEach((el) => observer.observe(el));
</script>
